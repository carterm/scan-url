{
  "$schema": "./../../schemas/domain-scan.schema.json",
  "domain": "ebt.ca.gov",
  "targetURL": "https://www.ebt.ca.gov/cardholder/",
  "www": true,
  "goodScan": true,
  "active": true,
  "includeInScan": true,
  "title": "CardHolder Portal",
  "lastStatus": 200,
  "cloudflare": false,
  "slow": false,
  "hasStatewideAlerts": false,
  "usesStateTemplate": false,
  "hasJQuery": false,
  "googleAnalytics": [],
  "socialLinks": [],
  "linksToCaGov": false,
  "errorMessage": null,
  "nocache": false,
  "responseHeaders": {
    "accept-ranges": "bytes",
    "access-control-allow-origin": "*.ebt.ca.gov",
    "connection": "keep-alive",
    "content-encoding": "gzip",
    "content-language": "und",
    "content-type": "text/html",
    "x-content-type-options": "nosniff",
    "x-frame-options": "SAMEORIGIN",
    "x-xss-protection": "1; mode=block"
  },
  "notes": null
}