{
  "$schema": "./../../schemas/domain-scan.schema.json",
  "domain": "cpads.sco.ca.gov",
  "targetURL": "https://cpads.sco.ca.gov/",
  "www": false,
  "active": true,
  "includeInScan": true,
  "title": "State Controller's Office CPA Directory Service (CPADS)",
  "lastStatus": 200,
  "responseHeaders": {
    "connection": "keep-alive",
    "content-encoding": "gzip",
    "content-type": "text/html; charset=utf-8",
    "expect-ct": "max-age=86400, enforce",
    "referrer-policy": "same-origin",
    "server": "cloudflare",
    "x-content-type-options": "nosniff",
    "x-frame-options": "SAMEORIGIN",
    "x-xss-protection": "1; mode=block"
  },
  "cloudflare": false,
  "slow": false,
  "hasStatewideAlerts": false,
  "usesStateTemplate": false,
  "hasJQuery": false,
  "googleAnalytics": [
    "GTM-MWCXZTZ"
  ],
  "socialLinks": [],
  "linksToCaGov": false,
  "errorMessage": null,
  "notes": null,
  "nocache": false,
  "goodScan": true,
  "metaAuthor": "State of California"
}