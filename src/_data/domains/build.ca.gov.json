{
  "$schema": "./../../schemas/domain-scan.schema.json",
  "domain": "build.ca.gov",
  "targetURL": "https://www.build.ca.gov/",
  "www": true,
  "active": true,
  "includeInScan": true,
  "title": "Building California: Transforming Infrastructure for a Better Future | Home",
  "lastStatus": 200,
  "responseHeaders": {
    "access-control-allow-credentials": "true",
    "access-control-allow-headers": "X-Requested-With, Content-Type, Authorization",
    "access-control-allow-methods": "GET, POST, PUT, DELETE, OPTIONS",
    "access-control-allow-origin": "*",
    "content-encoding": "br",
    "content-type": "text/html; charset=utf-8",
    "cross-origin-embedder-policy": "unsafe-none",
    "cross-origin-opener-policy": "same-origin-allow-popups",
    "cross-origin-resource-policy": "cross-origin",
    "permissions-policy": "camera=(), microphone=(), geolocation=()",
    "referrer-policy": "no-referrer",
    "server": "Vercel",
    "x-content-type-options": "nosniff",
    "x-dns-prefetch-control": "on",
    "x-frame-options": "SAMEORIGIN",
    "x-matched-path": "/en-US",
    "x-vercel-cache": "MISS",
    "x-xss-protection": "1; mode=block"
  },
  "cloudflare": false,
  "slow": false,
  "hasStatewideAlerts": false,
  "usesStateTemplate": false,
  "hasJQuery": false,
  "googleAnalytics": [],
  "socialLinks": [
    "https://twitter.com/CaltransHQ?ref_src=twsrc%5Egoogle%7Ctwcamp%5Eserp%7Ctwgr%5Eauthor",
    "https://www.facebook.com/CaltransHQ/",
    "https://www.linkedin.com/company/caltrans/",
    "https://www.youtube.com/@CaltransVideo"
  ],
  "linksToCaGov": true,
  "errorMessage": null,
  "notes": null,
  "nocache": true,
  "goodScan": true
}